# Copy to .env and fill in values

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: override public site URL (defaults to https://bookly.my in src/lib/site.ts)
# VITE_SITE_URL=https://bookly.my

# Optional: if the deployed slug differs (e.g. Dashboard shows .../functions/v1/rapid-processor)
# VITE_SUPABASE_SEND_TEST_EMAILS_FUNCTION=rapid-processor
